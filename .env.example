# Shopping Truth Agent — API Keys
# Copy this file to .env and fill in your keys
# cp .env.example .env

# ─────────────────────────────────────────────────────────────────────────────
# LLM KEY (REQUIRED — pick ONE of these)
# The agent needs at least one LLM to generate the AI verdict
# ─────────────────────────────────────────────────────────────────────────────

OPENAI_API_KEY=                 # https://platform.openai.com/api-keys
                                # Cost: ~$0.01 per analysis (GPT-4o-mini)

# ANTHROPIC_API_KEY=            # https://console.anthropic.com/
                                # Cost: ~$0.01 per analysis (Claude Haiku)

# GEMINI_API_KEY=               # https://aistudio.google.com/app/apikey
                                # Free tier available!

# GROK_API_KEY=                 # https://console.x.ai/
# OPENROUTER_API_KEY=           # https://openrouter.ai/keys (access ALL models)


# ─────────────────────────────────────────────────────────────────────────────
# DATA SOURCES (OPTIONAL — each one adds more analysis depth)
# ─────────────────────────────────────────────────────────────────────────────

# YouTube Data API v3 — Better video review search + view counts
# Free: 10,000 units/day | Signup: https://console.cloud.google.com/
YOUTUBE_API_KEY=

# SerpAPI — Google Shopping prices + alternatives
# Free: 100 searches/mo | Cost: $50/mo | Signup: https://serpapi.com/
SERPAPI_KEY=

# Rainforest API — 100+ Amazon reviews (best quality)
# Paid only | Cost: from $80/mo | Signup: https://www.rainforestapi.com/
RAINFOREST_API_KEY=

# ScrapingDog — 100+ Amazon reviews (cheaper alternative to Rainforest)
# Free: 1,000 credits/mo | Cost: $30/mo | Signup: https://www.scrapingdog.com/
SCRAPINGDOG_API_KEY=

# Keepa — Price history trends (was it cheaper last month?)
# Paid only | Cost: €19/mo | Signup: https://keepa.com/#!api
KEEPA_API_KEY=

# Reddit — Real user discussions from subreddits
# Free | Signup: https://www.reddit.com/prefs/apps → Create Script App
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# BROWSER SERVER (AUTO-DETECTED — only set if Camoufox is not auto-found)
# ─────────────────────────────────────────────────────────────────────────────

# CAMOUFOX_TOKEN=               # Auto-detected from /data/browser-server-token
# CAMOUFOX_PORT=9222            # Default port
