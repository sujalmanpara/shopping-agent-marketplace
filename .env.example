# ============================================================
# Shopping Truth Agent — API Keys
# Copy this to .env and fill in your keys
# ============================================================

# ── LLM PROVIDER (pick ONE — auto-detected in priority order) ──
# Set LLM_PROVIDER to force a specific one (openai/anthropic/gemini/grok/openrouter)

# Option 1: OpenAI (GPT-4o-mini)
# Signup: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Option 2: Anthropic (Claude Sonnet)
# Signup: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Option 3: Google Gemini (Gemini 2.0 Flash)
# Signup: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Option 4: xAI Grok (Grok-3-mini-fast)
# Signup: https://console.x.ai/
GROK_API_KEY=

# Option 5: OpenRouter (any model — free tier available!)
# Signup: https://openrouter.ai/ — free models like gemini-2.0-flash-exp
OPENROUTER_API_KEY=

# Force a specific provider (optional):
# LLM_PROVIDER=openai

# ── DATA SOURCES ─────────────────────────────────────────────

# YouTube reviews (FREE — required)
# Get at: https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=

# ── AMAZON DATA (pick one) ────────────────────────────────────
# Option A: Rainforest API — enterprise-grade, most reliable
# Signup: https://www.rainforestapi.com/ | Plans from ~$100/mo
RAINFOREST_API_KEY=

# Option B: ScrapingDog — generous free tier (1,000 req/mo FREE)
# Signup: https://www.scrapingdog.com/amazon-scraper | Paid: $30/mo
SCRAPINGDOG_API_KEY=

# If neither is set → HTTP fallback (works on home/laptop, blocked on cloud)

# ── PRICE COMPARISON (recommended) ───────────────────────────
# Get at: https://serpapi.com/ | Free trial: 100 searches
SERPAPI_KEY=

# ── PRICE HISTORY (optional, enhances predictions) ───────────
# Get at: https://keepa.com/#!api | Cost: €15/month
KEEPA_API_KEY=
