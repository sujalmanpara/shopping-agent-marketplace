# Shopping Truth Agent — API Keys
# Copy this to .env and fill in your keys

# REQUIRED (free)
OPENAI_API_KEY=sk-...          # openai.com — LLM verdict
YOUTUBE_API_KEY=AIza...        # console.cloud.google.com — video reviews

# RECOMMENDED (free trial available)
SERPAPI_KEY=...                # serpapi.com — price comparison + alternatives

# OPTIONAL paid
KEEPA_API_KEY=...              # keepa.com — price history + prediction (€15/mo)

# OPTIONAL (needs Amazon Associates account)
AMAZON_ACCESS_KEY=...
AMAZON_SECRET_KEY=...
AMAZON_PARTNER_TAG=...

# DEFERRED
# REDDIT_CLIENT_ID=...
# REDDIT_CLIENT_SECRET=...
