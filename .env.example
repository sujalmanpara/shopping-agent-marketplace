# ============================================================
# Shopping Truth Agent — API Keys
# Copy this to .env and fill in your keys
# ============================================================

# ── REQUIRED (free) ──────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Get at: https://platform.openai.com/api-keys
# Used for: LLM verdict generation (~$0.01 per run)

YOUTUBE_API_KEY=AIza...
# Get at: https://console.cloud.google.com/apis/library/youtube.googleapis.com
# Used for: Video reviews | Free: 10,000 units/day

# ── AMAZON DATA (pick one) ────────────────────────────────────
# Option A: Rainforest API — enterprise-grade, most reliable
# Signup: https://www.rainforestapi.com/
# Plans from ~$100/mo | Best for production use
RAINFOREST_API_KEY=

# Option B: ScrapingDog — great free tier (1,000 req/mo FREE)
# Signup: https://www.scrapingdog.com/amazon-scraper
# Free: 1,000/mo | Paid: $30/mo for 10,000 req
SCRAPINGDOG_API_KEY=

# Note: If neither key is set, the agent falls back to HTTP fetch.
# HTTP fallback works on residential IPs (home/laptop) but may
# fail on cloud/VPS servers. For cloud deployment, use one of the above.

# ── PRICE COMPARISON (recommended) ───────────────────────────
SERPAPI_KEY=
# Get at: https://serpapi.com/ | Free trial: 100 searches
# Used for: Cross-store price comparison + alternatives finder

# ── PRICE HISTORY (optional, enhances predictions) ───────────
KEEPA_API_KEY=
# Get at: https://keepa.com/#!api | Cost: €15/month
# Used for: 6-month price history → powers ARIMA price prediction

# ── DEFERRED (not needed for current version) ─────────────────
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# AMAZON_ACCESS_KEY=     ← PA-API deprecated April 2026
# AMAZON_SECRET_KEY=
# AMAZON_PARTNER_TAG=
